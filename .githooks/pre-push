#!/usr/bin/env bash
# Gate every push: the api/ mirror must match the canonical tree, and
# the offline rubric must be GREEN. Enable once per clone with:
#   git config core.hooksPath .githooks
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"
scripts/sync_api.sh > /dev/null
if ! git diff --quiet -- api; then
  echo "pre-push: api/ mirror was stale — synced it; commit the changes and push again." >&2
  exit 1
fi
python3 -m simsoc validate --smoke > /dev/null || {
  echo "pre-push: offline rubric (validate --smoke) is RED." >&2; exit 1; }
